#!/usr/bin/env python

import sys, os, gc
import argparse
import matplotlib.pyplot as plt
import numpy as np
import astropy.io.fits as pyfits
from desispec.io import read_xytraceset
import fitsio

parser = argparse.ArgumentParser(formatter_class=argparse.ArgumentDefaultsHelpFormatter,
                                 description="PCA of sky corrections")
parser.add_argument('-i','--infile', type = str, default = None, required = True, nargs="*",
                    help = 'path to skycorr fits files')
parser.add_argument('-o','--outfile', type = str, default = None, required = True,
                    help = 'output fits file with PCA coefficients')
parser.add_argument('--ncomp', type = int, default = 6, required = False,
                    help = 'number of PCA components to save (in addition to the mean)')
parser.add_argument('--min-exptime', type = float, default = 700, required = False,
                    help = 'minimum exposure time (to ensure a good precision on sky lines)')
parser.add_argument('--min-nexp', type = int, default = 50, required = False,
                    help = 'the minimum required number of good exposures')
parser.add_argument('--max-nexp', type = int, default = None, required = False,
                    help = 'randomly downsample to max_nexp if the number good exposures exceeds max_nexp')
parser.add_argument('--first-night', type = int, required = False,
                    help = 'exposures taken before first_night are ignored')
parser.add_argument('--last-night', type = int, required = False,
                    help = 'exposures taken after last_night are ignored')
args = parser.parse_args()


if os.path.isfile(args.outfile):
    print(args.outfile, 'already exists; exit')
    sys.exit()

output_hdulist=pyfits.HDUList()
first=True

wave=None
head=None
night_min=None
night_max=None
nexp_dict = {}

for what in [ "DWAVE" , "DLSF" ] :
    deltas=[]
    print("processing",what)
    print("reading {} files".format(len(args.infile)))
    for index,filename in enumerate(args.infile) :

        print("reading {}/{} {}".format(index+1,len(args.infile),filename))

        frame_filename=filename.replace("skycorr-","frame-")
        if not os.path.isfile(frame_filename) :
            print("warning: cannot open frame file {}".format(frame_filename))
            continue

        # A hack to get NIGHT without having to read the gzipped file
        fn_split = frame_filename.split('/')
        night = int(fn_split[fn_split.index('exposures')+1])

        if args.first_night is not None and night < args.first_night:
            print("ignore {} with night={} < {}".format(filename,night,args.first_night))
            continue
        if args.last_night is not None and night > args.last_night:
            print("ignore {} with night={} > {}".format(filename,night,args.last_night))
            continue

        if args.min_exptime!=0:
            # It's super inefficient to read the fits.gz files just to get EXPTIME
            head=fitsio.read_header(frame_filename)
            exptime=head["EXPTIME"]
            if exptime < args.min_exptime :
                print("ignore {} with exptime={} < {}".format(filename,exptime,args.min_exptime))
                continue

        # night=head["NIGHT"]

        if night_min is None :
            night_min = night
            night_max = night
        else :
            night_min = min(night_min,night)
            night_max = max(night_max,night)

        h=pyfits.open(filename)
        delta=h[what].data
        rms=np.std(delta)
        if rms==0 or rms>1.:
            print("{}: no valid data for {}; rms = {}".format(what, filename, rms))
            continue
        print("{} rms {} = {}".format(os.path.basename(filename),what,rms))

        if what=="DWAVE" :
            threshold=0.3
        elif what=="DLSF" :
            threshold=2.
        else:
            print(f"ERROR: unknown threshold for {what}; please update code")
            sys.exit(1)

        # Mask bad fibers instead of skipping entire exposure
        mask = np.abs(delta) > threshold
        if np.any(mask):
            n_bad = np.sum(mask)
            maxdelta = np.max(np.abs(delta))
            print(f"masking {n_bad} bad elements in {filename} with max |{what}| = {maxdelta:.3f} > {threshold}")
            delta = delta.copy()  # Make a copy to avoid modifying the original
            delta[mask] = np.nan

        deltas.append(delta)

        if wave is None :
            wave=h["WAVELENGTH"].data

    if len(deltas)<args.min_nexp:
        print('A minimum of {} exposures are required; only {} exposures available\n{}'.format(args.min_nexp, len(deltas), args.outfile))
        sys.exit()

    if args.max_nexp is not None and len(deltas)>args.max_nexp:
        print('Downsampling the number of exposures from {} to {}'.format(len(deltas), args.max_nexp))
        np.random.seed(123)
        idx = np.sort(np.random.choice(len(deltas), size=args.max_nexp, replace=False))
        deltas1 = []
        for index in idx:
            deltas1.append(deltas[index])
        deltas = deltas1

    nmeas = len(deltas)
    nexp_dict[what] = nmeas

    print("convert to array")
    deltas=np.array(deltas)
    print("number of measurements=",deltas.shape[0])

    gc.collect()

    print("subtract mean")
    mdeltas=np.nanmean(deltas,axis=0)
    # Replace NaN in mean with 0 (positions where all exposures are bad)
    mdeltas[np.isnan(mdeltas)] = 0.
    deltas[:] -= mdeltas
    # Replace remaining NaN with 0 (positions where individual exposures are bad)
    deltas[np.isnan(deltas)] = 0.

    print("fill scalar product matrix")
    # Reshape to (nmeas, nfibers*nwave) for vectorized dot product
    deltas_flat = deltas.reshape(nmeas, -1)
    mat = np.dot(deltas_flat, deltas_flat.T)

    print("eigen decomposition")
    eigenvals,v = np.linalg.eig(mat)
    eigenvals=np.real(eigenvals)
    v=np.real(v)
    eigenvals[eigenvals<0]=0.
    ii=np.argsort(eigenvals)[::-1]
    print("eigen vals")
    print(eigenvals[ii])

    # testing
    #print(mat.dot(v[:,5]),"=?",eigenvals[5]*v[:,5])


    if first :
        output_hdulist.append(pyfits.PrimaryHDU(mdeltas))
        output_hdulist[0].header["EXTNAME"]=what+"_MEAN"
        first=False
    else :
        output_hdulist.append(pyfits.ImageHDU(mdeltas,name=what+"_MEAN"))

    ncomp=args.ncomp
    for e,i in enumerate(ii[:ncomp]) :
        vv=v[:,i] # eigen vector i with eigen value of rank e+1
        tmp=np.zeros(mdeltas.shape)
        for j in range(v.shape[0]) :
            tmp += vv[j]*deltas[j]
        output_hdulist.append(pyfits.ImageHDU(tmp,name=what+"_EIG{}".format(e+1)))

    output_hdulist.append(pyfits.ImageHDU(eigenvals[ii][:40],name=what+"_EIGENVALS"))

output_hdulist.append(pyfits.ImageHDU(wave,name="WAVELENGTH"))
head=fitsio.read_header(frame_filename)
for k in ["CAMERA","DETECTOR"] :
    output_hdulist[0].header[k]=head[k]
if night_min is not None :
    output_hdulist[0].header["NIGHTMIN"] = (night_min, 'First night of input exposures')
    output_hdulist[0].header["NIGHTMAX"] = (night_max, 'Last night of input exposures')
output_hdulist[0].header['NEXPDW'] = (nexp_dict['DWAVE'], 'Number of input exposures used for DWAVE')
output_hdulist[0].header['NEXPDL'] = (nexp_dict['DLSF'], 'Number of input exposures used for DLSF')
output_hdulist.writeto(args.outfile,overwrite=True)
print("wrote",args.outfile)
